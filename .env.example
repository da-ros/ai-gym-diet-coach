# Anthropic Claude API (vision + nutrition + coaching + chat)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL connection string (Supabase → Settings → Database → Connection string → URI, port 6543)
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres

# Supabase JWT secret (Settings → API → JWT Keys → Legacy JWT Secret tab → Reveal)
SUPABASE_JWT_SECRET=your_supabase_jwt_secret_here

# Supabase project URL — required to verify ECC-signed tokens (new signing keys)
# e.g. https://YOUR_PROJECT_REF.supabase.co  (same as frontend VITE_SUPABASE_URL)
SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co

# Backend URL (used by the Vite frontend via import.meta.env.VITE_API_URL)
VITE_API_URL=http://localhost:8000

# Frontend auth: copy these to apps/frontend/.env (Supabase → Settings → API)
# VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
# VITE_SUPABASE_ANON_KEY=your_anon_public_key_here
